//@version=5
indicator("SMC — Liquidity (BSL / SSL)", overlay=true, max_bars_back=500)

// --- INPUTS ---
// Valores por defecto calibrados para EURUSD (H1/H4) y XAUUSD (H1/H4).
// EURUSD: ATR H1 ≈ 10-20 pips  |  XAUUSD: ATR H1 ≈ $5-15
i_leftBars  = input.int(5,     "Left Bars",                     minval=1, maxval=50, group="Pivot Detection",
     tooltip="Velas a la izquierda para confirmar el swing.\nEURUSD H1: 5 | XAUUSD H1: 5 | H4 ambos: 7")
i_rightBars = input.int(3,     "Right Bars",                    minval=1, maxval=50, group="Pivot Detection",
     tooltip="Velas a la derecha para confirmar el swing.\nH1 ambos: 3 | H4 ambos: 5")
i_maxLevels = input.int(5,     "Max niveles activos",           minval=1, maxval=20, group="Liquidity")
i_showSwept = input.bool(true, "Mostrar niveles barridos",                           group="Liquidity")
i_eqThresh  = input.float(0.15, "EQH/EQL tolerancia (× ATR)",  minval=0.0, step=0.05, group="Liquidity",
     tooltip="Dos swings son 'iguales' (EQH/EQL) si su diferencia < N × ATR.\nEURUSD H1: 0.10-0.15 | XAUUSD H1: 0.15-0.20\nValores mayores detectan más patrones pero aumentan falsos positivos.")
i_atrLen    = input.int(14,    "ATR Period",                    minval=1,             group="Liquidity")
i_colorBSL  = input.color(color.new(#2962FF,  0), "BSL (Buy-Side Liquidity)",        group="Colors")
i_colorSSL  = input.color(color.new(#FF6D00,  0), "SSL (Sell-Side Liquidity)",       group="Colors")
i_colorSwept= input.color(color.new(#787B86, 60), "Nivel Barrido",                   group="Colors")
i_colorEQ   = input.color(color.new(#AA00FF,  0), "Equal High / Low (EQH/EQL)",      group="Colors")

// --- FUNCIONES ---

// Elimina el nivel más antiguo de un grupo de arrays (reference types en Pine Script v5)
f_evictLevel(lines, levels, bars, active) =>
    ln = array.shift(lines)
    if not na(ln)
        line.delete(ln)
    array.shift(levels)
    array.shift(bars)
    array.shift(active)

// --- LÓGICA PRINCIPAL ---

atr      = ta.atr(i_atrLen)
pivotBar = bar_index - i_rightBars

swingHigh = ta.pivothigh(high, i_leftBars, i_rightBars)
swingLow  = ta.pivotlow(low,  i_leftBars, i_rightBars)

// Último swing high/low confirmado — para calcular tolerancia EQH/EQL
var float prevSH = na
var float prevSL = na

// Arrays para BSL: swing highs no barridos (stops de cortos clustered encima)
var bslLevels = array.new_float()
var bslBars   = array.new_int()
var bslLines  = array.new_line()
var bslActive = array.new_bool()

// Arrays para SSL: swing lows no barridos (stops de largos clustered debajo)
var sslLevels = array.new_float()
var sslBars   = array.new_int()
var sslLines  = array.new_line()
var sslActive = array.new_bool()

// Registrar nuevo nivel de BSL en cada swing high confirmado
if not na(swingHigh)
    // EQH: dos swing highs consecutivos dentro de la tolerancia → liquidez doble, zona más potente
    isEQH = not na(prevSH) and math.abs(swingHigh - prevSH) <= atr * i_eqThresh
    if isEQH
        label.new(pivotBar, swingHigh, "EQH",
             color     = color.new(i_colorEQ, 80),
             textcolor = i_colorEQ,
             style     = label.style_label_down,
             size      = size.tiny)
    prevSH := swingHigh

    if array.size(bslLevels) >= i_maxLevels
        f_evictLevel(bslLines, bslLevels, bslBars, bslActive)
    bslLine = line.new(pivotBar, swingHigh, bar_index, swingHigh,
         color  = i_colorBSL,
         width  = 1,
         style  = line.style_dotted,
         extend = extend.right)
    array.push(bslLevels, swingHigh)
    array.push(bslBars,   pivotBar)
    array.push(bslLines,  bslLine)
    array.push(bslActive, true)

// Registrar nuevo nivel de SSL en cada swing low confirmado
if not na(swingLow)
    // EQL: dos swing lows consecutivos dentro de la tolerancia → liquidez doble, zona más potente
    isEQL = not na(prevSL) and math.abs(swingLow - prevSL) <= atr * i_eqThresh
    if isEQL
        label.new(pivotBar, swingLow, "EQL",
             color     = color.new(i_colorEQ, 80),
             textcolor = i_colorEQ,
             style     = label.style_label_up,
             size      = size.tiny)
    prevSL := swingLow

    if array.size(sslLevels) >= i_maxLevels
        f_evictLevel(sslLines, sslLevels, sslBars, sslActive)
    sslLine = line.new(pivotBar, swingLow, bar_index, swingLow,
         color  = i_colorSSL,
         width  = 1,
         style  = line.style_dotted,
         extend = extend.right)
    array.push(sslLevels, swingLow)
    array.push(sslBars,   pivotBar)
    array.push(sslLines,  sslLine)
    array.push(sslActive, true)

// Detectar barreduras de BSL: el WICK supera el nivel (los stops se activan por high/low, no por close)
// Un cierre por encima es un BOS; una barredura con wick y rechazo es toma de liquidez SMC.
var bool sweptBSL = false
sweptBSL := false
bslCount = array.size(bslLevels)
if bslCount > 0
    for i = 0 to bslCount - 1
        if array.get(bslActive, i)
            lvl = array.get(bslLevels, i)
            ln  = array.get(bslLines,  i)
            if high > lvl
                array.set(bslActive, i, false)
                sweptBSL := true
                if i_showSwept
                    line.set_color(ln,  i_colorSwept)
                    line.set_style(ln,  line.style_dashed)
                    line.set_extend(ln, extend.none)
                    line.set_x2(ln, bar_index)
                    label.new(bar_index, lvl, "BSL swept",
                         color     = color.new(i_colorSwept, 80),
                         textcolor = i_colorSwept,
                         style     = label.style_label_left,
                         size      = size.tiny)
                else
                    line.delete(ln)
                    array.set(bslLines, i, na)

// Detectar barreduras de SSL: el WICK perfora el nivel por debajo
var bool sweptSSL = false
sweptSSL := false
sslCount = array.size(sslLevels)
if sslCount > 0
    for i = 0 to sslCount - 1
        if array.get(sslActive, i)
            lvl = array.get(sslLevels, i)
            ln  = array.get(sslLines,  i)
            if low < lvl
                array.set(sslActive, i, false)
                sweptSSL := true
                if i_showSwept
                    line.set_color(ln,  i_colorSwept)
                    line.set_style(ln,  line.style_dashed)
                    line.set_extend(ln, extend.none)
                    line.set_x2(ln, bar_index)
                    label.new(bar_index, lvl, "SSL swept",
                         color     = color.new(i_colorSwept, 80),
                         textcolor = i_colorSwept,
                         style     = label.style_label_left,
                         size      = size.tiny)
                else
                    line.delete(ln)
                    array.set(sslLines, i, na)

// --- PLOTS ---
plotshape(sweptBSL, "BSL Barrida", shape.xcross, location.abovebar, i_colorBSL,  size=size.small)
plotshape(sweptSSL, "SSL Barrida", shape.xcross, location.belowbar, i_colorSSL,  size=size.small)

// --- ALERTAS ---
alertcondition(sweptBSL,             "BSL Barrida",       "SMC | BSL barrida — liquidez alcista tomada, buscar reversión bajista en OB/FVG")
alertcondition(sweptSSL,             "SSL Barrida",       "SMC | SSL barrida — liquidez bajista tomada, buscar reversión alcista en OB/FVG")
alertcondition(sweptBSL or sweptSSL, "Liquidez Barrida",  "SMC | Liquidez barrida — confluir con OB/FVG/CHoCH antes de entrar")
