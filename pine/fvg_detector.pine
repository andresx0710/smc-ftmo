//@version=5
indicator("SMC — Fair Value Gaps", overlay=true, max_bars_back=500)

// --- INPUTS ---
i_maxFVGs    = input.int(5,     "Max FVGs activos",       minval=1, maxval=20, group="Fair Value Gaps")
i_minTicks   = input.int(5,     "Tamaño mínimo (ticks)",  minval=0,            group="Fair Value Gaps",
     tooltip="Filtra FVGs más pequeños que N ticks. 1 tick = syminfo.mintick del instrumento. 0 = mostrar todos.")
i_showMitig  = input.bool(true, "Mostrar FVGs mitigados",                       group="Fair Value Gaps")
i_colorBull  = input.color(color.new(#00C853, 85), "FVG Alcista",               group="Colors")
i_colorBear  = input.color(color.new(#D50000, 85), "FVG Bajista",               group="Colors")
i_colorMitig = input.color(color.new(#787B86, 92), "FVG Mitigado",              group="Colors")
i_bdrBull    = input.color(color.new(#00C853, 20), "Borde Alcista",             group="Colors")
i_bdrBear    = input.color(color.new(#D50000, 20), "Borde Bajista",             group="Colors")
i_bdrMitig   = input.color(color.new(#787B86, 60), "Borde Mitigado",            group="Colors")

// --- FUNCIONES ---

// Elimina el FVG más antiguo de los arrays (arrays son reference types en Pine Script v5)
f_evictOldest(boxes, tops, bottoms, startBars, types, active) =>
    bx = array.shift(boxes)
    if not na(bx)
        box.delete(bx)
    array.shift(tops)
    array.shift(bottoms)
    array.shift(startBars)
    array.shift(types)
    array.shift(active)

// --- LÓGICA PRINCIPAL ---

// Detección del patrón de 3 velas (smc-concepts.md).
// Indexado en Pine Script: [0] = vela actual (3ª/más reciente), [2] = hace 2 barras (1ª/más antigua).
//
// FVG alcista:  low[0] > high[2]   →   zona: [high[2], low[0]]
// FVG bajista:  high[0] < low[2]   →   zona: [high[0], low[2]]
//
// La vela 2 (middle, [1]) no participa en la condición — solo las mechas externas importan.
minGap = i_minTicks * syminfo.mintick

fvgBullBottom = high[2]
fvgBullTop    = low[0]
fvgBearBottom = high[0]
fvgBearTop    = low[2]

fvgBull = fvgBullTop > fvgBullBottom and (fvgBullTop - fvgBullBottom) >= minGap
fvgBear = fvgBearTop > fvgBearBottom and (fvgBearTop - fvgBearBottom) >= minGap

// El borde izquierdo del box corresponde a la vela 1 (la más antigua del patrón)
fvgStartBar = bar_index - 2

// Arrays paralelos — un índice por FVG
var fvgTops    = array.new_float()
var fvgBottoms = array.new_float()
var fvgBars    = array.new_int()     // bar_index de la vela 1 (borde izquierdo del box)
var fvgTypes   = array.new_string()  // "bull" | "bear"
var fvgBoxes   = array.new_box()
var fvgActive  = array.new_bool()    // true = activo, false = mitigado

// Registrar FVG alcista
if fvgBull
    if array.size(fvgTops) >= i_maxFVGs
        f_evictOldest(fvgBoxes, fvgTops, fvgBottoms, fvgBars, fvgTypes, fvgActive)
    newBox = box.new(fvgStartBar, fvgBullTop, bar_index, fvgBullBottom,
         bgcolor      = i_colorBull,
         border_color = i_bdrBull,
         border_width = 1,
         extend       = extend.right)
    label.new(fvgStartBar, fvgBullTop, "FVG ↑",
         color     = color.new(i_bdrBull, 80),
         textcolor = i_bdrBull,
         style     = label.style_label_right,
         size      = size.tiny)
    array.push(fvgTops,    fvgBullTop)
    array.push(fvgBottoms, fvgBullBottom)
    array.push(fvgBars,    fvgStartBar)
    array.push(fvgTypes,   "bull")
    array.push(fvgBoxes,   newBox)
    array.push(fvgActive,  true)

// Registrar FVG bajista
if fvgBear
    if array.size(fvgTops) >= i_maxFVGs
        f_evictOldest(fvgBoxes, fvgTops, fvgBottoms, fvgBars, fvgTypes, fvgActive)
    newBox = box.new(fvgStartBar, fvgBearTop, bar_index, fvgBearBottom,
         bgcolor      = i_colorBear,
         border_color = i_bdrBear,
         border_width = 1,
         extend       = extend.right)
    label.new(fvgStartBar, fvgBearBottom, "FVG ↓",
         color     = color.new(i_bdrBear, 80),
         textcolor = i_bdrBear,
         style     = label.style_label_right,
         size      = size.tiny)
    array.push(fvgTops,    fvgBearTop)
    array.push(fvgBottoms, fvgBearBottom)
    array.push(fvgBars,    fvgStartBar)
    array.push(fvgTypes,   "bear")
    array.push(fvgBoxes,   newBox)
    array.push(fvgActive,  true)

// Comprobar mitigación en cada vela para todos los FVGs activos.
// Guarda de formación: se omite la verificación en las 2 barras del patrón de 3 (bar_index > fvgBar + 2)
// para evitar falsos positivos en la barra de detección.
// Mitigación: precio cierra dentro del rango [fvgBottom, fvgTop] (smc-concepts.md).
fvgCount = array.size(fvgTops)
if fvgCount > 0
    for i = 0 to fvgCount - 1
        if array.get(fvgActive, i) and bar_index > array.get(fvgBars, i) + 2
            top    = array.get(fvgTops,    i)
            bottom = array.get(fvgBottoms, i)
            bx     = array.get(fvgBoxes,   i)

            if close >= bottom and close <= top
                array.set(fvgActive, i, false)
                if i_showMitig
                    box.set_right(bx, bar_index)
                    box.set_extend(bx, extend.none)
                    box.set_bgcolor(bx, i_colorMitig)
                    box.set_border_color(bx, i_bdrMitig)
                else
                    box.delete(bx)
                    array.set(fvgBoxes, i, na)

// --- PLOTS ---
plotshape(fvgBull, "FVG Alcista", shape.triangleup,   location.belowbar,
     color=color.new(#00C853, 0), size=size.tiny)
plotshape(fvgBear, "FVG Bajista", shape.triangledown, location.abovebar,
     color=color.new(#D50000, 0), size=size.tiny)

// --- ALERTAS ---
alertcondition(fvgBull, "FVG Alcista detectado", "SMC | FVG Alcista — imbalance alcista, posible retorno al rango")
alertcondition(fvgBear, "FVG Bajista detectado", "SMC | FVG Bajista — imbalance bajista, posible retorno al rango")
