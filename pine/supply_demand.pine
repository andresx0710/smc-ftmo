//@version=5
indicator("SMC — Supply & Demand Zones", overlay=true, max_bars_back=500)

// --- INPUTS ---
i_atrLen        = input.int(14,    "ATR Period",                   minval=1,             group="Zone Detection")
i_baseThresh    = input.float(0.5, "Base: cuerpo máx (× ATR)",    minval=0.1, step=0.1, group="Zone Detection",
     tooltip="Una vela es 'base' si su cuerpo < N × ATR. Reduce para zonas más selectivas.")
i_impulseThresh = input.float(1.5, "Impulso: cuerpo mín (× ATR)", minval=0.5, step=0.1, group="Zone Detection",
     tooltip="Una vela es 'impulso' si su cuerpo > N × ATR. Aumenta para filtrar impulsos débiles.")
i_maxBaseLen    = input.int(5,     "Max velas en la base",         minval=1, maxval=15,  group="Zone Detection",
     tooltip="Máximo de velas consecutivas de consolidación que forman el rango de la zona.")
i_maxZones      = input.int(3,     "Max zonas activas",            minval=1, maxval=10,  group="Supply & Demand")
i_showMitig     = input.bool(true, "Mostrar zonas mitigadas",                            group="Supply & Demand")
i_colorDemand   = input.color(color.new(#00C853, 80), "Zona Demanda",                   group="Colors")
i_colorSupply   = input.color(color.new(#D50000, 80), "Zona Oferta",                    group="Colors")
i_colorMitig    = input.color(color.new(#787B86, 90), "Zona Mitigada",                  group="Colors")
i_bdrDemand     = input.color(color.new(#00C853,  0), "Borde Demanda",                  group="Colors")
i_bdrSupply     = input.color(color.new(#D50000,  0), "Borde Oferta",                   group="Colors")
i_bdrMitig      = input.color(color.new(#787B86, 50), "Borde Mitigado",                 group="Colors")

// --- FUNCIONES ---

// Escanea hacia atrás desde bar[1] buscando velas de BASE consecutivas (smc-concepts.md:
// "consolidación lateral"). Se detiene en la primera vela que excede el umbral de base.
// Devuelve [zoneTop, zoneBottom, startBar] del rango consolidado.
f_findBase(maxLen, baseThresh, atrVal) =>
    zTop   = float(na)
    zBot   = float(na)
    zStart = int(na)
    for i = 1 to maxLen
        if math.abs(close[i] - open[i]) < atrVal * baseThresh
            zTop   := na(zTop) ? high[i] : math.max(zTop, high[i])
            zBot   := na(zBot) ? low[i]  : math.min(zBot, low[i])
            zStart := bar_index - i
        else
            break
    [zTop, zBot, zStart]

// Elimina la zona más antigua de todos los arrays (arrays son reference types en Pine Script v5)
f_evictOldest(boxes, tops, bottoms, startBars, types, active) =>
    bx = array.shift(boxes)
    if not na(bx)
        box.delete(bx)
    array.shift(tops)
    array.shift(bottoms)
    array.shift(startBars)
    array.shift(types)
    array.shift(active)

// --- LÓGICA PRINCIPAL ---

atr      = ta.atr(i_atrLen)
bodySize = math.abs(close - open)

// Velas de impulso: cuerpo que supera el umbral en una dirección clara
isImpulseBull = close > open and bodySize > atr * i_impulseThresh
isImpulseBear = close < open and bodySize > atr * i_impulseThresh

// Base inmediatamente anterior al impulso actual (smc-concepts.md: "zona = rango de la base")
// La función escanea desde bar[1] hacia atrás — el impulso en bar[0] no forma parte de la zona.
[baseTop, baseBot, baseStart] = f_findBase(i_maxBaseLen, i_baseThresh, atr)
baseFound = not na(baseTop)

// Arrays paralelos — un índice por zona
var zTops    = array.new_float()
var zBottoms = array.new_float()
var zBars    = array.new_int()
var zTypes   = array.new_string()  // "demand" | "supply"
var zBoxes   = array.new_box()
var zActive  = array.new_bool()    // true = activa, false = mitigada

// Zona de DEMANDA: base → impulso alcista (patrón DBR o RBR)
// "smc-concepts.md: demanda superó oferta, generando impulso alcista fuerte"
if isImpulseBull and baseFound
    if array.size(zTops) >= i_maxZones
        f_evictOldest(zBoxes, zTops, zBottoms, zBars, zTypes, zActive)
    newBox = box.new(baseStart, baseTop, bar_index, baseBot,
         bgcolor      = i_colorDemand,
         border_color = i_bdrDemand,
         border_width = 1,
         extend       = extend.right)
    label.new(baseStart, baseBot, "DEMAND",
         color     = color.new(i_bdrDemand, 80),
         textcolor = i_bdrDemand,
         style     = label.style_label_upper_right,
         size      = size.tiny)
    array.push(zTops,    baseTop)
    array.push(zBottoms, baseBot)
    array.push(zBars,    baseStart)
    array.push(zTypes,   "demand")
    array.push(zBoxes,   newBox)
    array.push(zActive,  true)

// Zona de OFERTA: base → impulso bajista (patrón RBD o DBD)
// "smc-concepts.md: oferta superó demanda, generando impulso bajista fuerte"
if isImpulseBear and baseFound
    if array.size(zTops) >= i_maxZones
        f_evictOldest(zBoxes, zTops, zBottoms, zBars, zTypes, zActive)
    newBox = box.new(baseStart, baseTop, bar_index, baseBot,
         bgcolor      = i_colorSupply,
         border_color = i_bdrSupply,
         border_width = 1,
         extend       = extend.right)
    label.new(baseStart, baseTop, "SUPPLY",
         color     = color.new(i_bdrSupply, 80),
         textcolor = i_bdrSupply,
         style     = label.style_label_lower_right,
         size      = size.tiny)
    array.push(zTops,    baseTop)
    array.push(zBottoms, baseBot)
    array.push(zBars,    baseStart)
    array.push(zTypes,   "supply")
    array.push(zBoxes,   newBox)
    array.push(zActive,  true)

// Comprobar mitigación en cada vela para todas las zonas activas.
// Guarda: se omiten las barras del propio patrón base + impulso para evitar falsos positivos.
// Mitigación: precio cierra dentro del rango [zoneBottom, zoneTop] (smc-concepts.md).
zCount = array.size(zTops)
if zCount > 0
    for i = 0 to zCount - 1
        if array.get(zActive, i) and bar_index > array.get(zBars, i) + i_maxBaseLen + 1
            top    = array.get(zTops,    i)
            bottom = array.get(zBottoms, i)
            bx     = array.get(zBoxes,   i)

            if close >= bottom and close <= top
                array.set(zActive, i, false)
                if i_showMitig
                    box.set_right(bx, bar_index)
                    box.set_extend(bx, extend.none)
                    box.set_bgcolor(bx, i_colorMitig)
                    box.set_border_color(bx, i_bdrMitig)
                else
                    box.delete(bx)
                    array.set(zBoxes, i, na)

// --- PLOTS ---
plotshape(isImpulseBull and baseFound, "Demanda detectada",
     shape.triangleup,   location.belowbar, color.new(#00C853, 0), size=size.tiny)
plotshape(isImpulseBear and baseFound, "Oferta detectada",
     shape.triangledown, location.abovebar, color.new(#D50000, 0), size=size.tiny)

// --- ALERTAS ---
alertcondition(isImpulseBull and baseFound, "Zona de Demanda",
     "SMC | Zona de Demanda — base + impulso alcista (DBR/RBR)")
alertcondition(isImpulseBear and baseFound, "Zona de Oferta",
     "SMC | Zona de Oferta — base + impulso bajista (RBD/DBD)")
