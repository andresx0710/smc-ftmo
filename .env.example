# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env a git — ya está en .gitignore.

# --- Telegram ---
# Obtén el token en @BotFather (Telegram)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# ID del chat donde el bot enviará las señales.
# Habla con @userinfobot en Telegram para obtener tu chat_id.
TELEGRAM_CHAT_ID=987654321

# --- Seguridad del webhook ---
# Token secreto que TradingView incluirá en la URL: ?secret=TU_TOKEN
# Genera uno aleatorio: python -c "import secrets; print(secrets.token_hex(24))"
WEBHOOK_SECRET=cambia_esto_por_un_valor_aleatorio_seguro

# --- Cloud Dashboard (Render / Railway) ---
# URL pública del servicio desplegado en la nube:
CLOUD_URL=https://smc-ftmo.onrender.com
# Token secreto para que el bot pueda hacer POST /push al cloud (= PUSH_TOKEN en Render):
CLOUD_TOKEN=genera_con_python_-c_import_secrets_print_secrets.token_hex_32

# --- MT5 (Phase 3 — sólo en Windows con MetaTrader5 instalado) ---
# Deja vacío para operar sólo con webhooks + Telegram (sin MT5).
# Credenciales de tu cuenta FTMO en MT5:
MT5_LOGIN=12345678
MT5_PASSWORD=tu_password_de_mt5
MT5_SERVER=ICMarkets-Demo02
# Ruta al ejecutable de MT5 (opcional — sólo si no está en la ruta por defecto):
# MT5_PATH=C:\Program Files\FTMO MetaTrader 5\terminal64.exe
# Intervalo de comprobación de cuenta en segundos (default: 30):
MT5_MONITOR_INTERVAL=30
